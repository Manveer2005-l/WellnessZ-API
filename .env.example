# IMPROVEMENT: Added .env.example for safe development setup
# Copy this file to .env and fill in actual values

# WellnessZ API Authentication
WELLNESSZ_API_KEY=your-api-key-here

# OpenAI API for explanation generation
OPENAI_API_KEY=sk-proj-your-key-here

# Data mode: NONE (local) or REMOTE (fetch from external API)
DATA_MODE=NONE

# External client API (required if DATA_MODE=REMOTE)
CLIENT_API_BASE_URL=https://api.example.com
CLIENT_API_KEY=your-client-api-key

# Flask environment
FLASK_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Cache TTL in seconds (for explanations)
CACHE_TTL=3600
